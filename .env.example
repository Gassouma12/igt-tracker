# Copy to .env and fill in from your Supabase project (Settings -> API).
# When BOTH are set, the app hydrates from Supabase and mirrors writes to it.
# When absent, the app runs entirely on the bundled mock/seed data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Set to true to use real Supabase Auth (email + password) for login/signup.
# Requires a seeded DB + a bootstrapped admin (see SUPABASE.md). Default off.
VITE_USE_SUPABASE_AUTH=false
